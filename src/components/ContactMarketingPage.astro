---
import EditorialLayout from '../layouts/EditorialLayout.astro';

const { lang } = Astro.props as { lang: 'fr' | 'en' };
const isFr = lang === 'fr';
const copy = isFr
  ? {
      title: 'Contacter Runaway', description: 'Une question, un problème ou une suggestion ? Contactez l’équipe Runaway.',
      canonical: '/contact', alternateFr: '/contact', alternateEn: '/en/contact', eyebrow: 'CONTACT',
      heading: 'Parlons de votre expérience.', intro: 'Une question sur Runaway, un problème à signaler ou une idée pour améliorer le produit ? Envoyez-moi un message.',
      directTitle: 'Le bon canal, simplement', directBody: 'Runaway est un produit indépendant. Chaque message est lu avec attention.',
      reasons: [['Question', 'Comprendre une fonctionnalité ou la méthodologie.'], ['Problème', 'Signaler un comportement inattendu dans l’application.'], ['Suggestion', 'Proposer une amélioration ou un nouveau besoin.']],
      formTitle: 'Envoyer un message', name: 'Nom', email: 'Email', subject: 'Sujet', message: 'Message',
      subjects: [['question', 'Question'], ['problem', 'Problème'], ['feature', 'Suggestion de fonctionnalité'], ['other', 'Autre']],
      placeholder: 'Décrivez votre demande en donnant le contexte utile…', send: 'Envoyer le message', sending: 'Envoi…',
      privacy: 'Ces informations sont utilisées uniquement pour traiter et répondre à votre demande. Ne communiquez pas de données financières sensibles dans ce formulaire.',
      success: 'Merci, votre message a bien été envoyé. Je vous répondrai dès que possible.',
      error: 'Le message n’a pas pu être envoyé. Réessayez dans quelques instants.',
    }
  : {
      title: 'Contact Runaway', description: 'Have a question, problem, or suggestion? Contact the Runaway team.',
      canonical: '/en/contact', alternateFr: '/contact', alternateEn: '/en/contact', eyebrow: 'CONTACT',
      heading: 'Let’s talk about your experience.', intro: 'Have a question about Runaway, an issue to report, or an idea that could improve the product? Send me a message.',
      directTitle: 'A straightforward way to reach out', directBody: 'Runaway is an independent product. Every message is read with care.',
      reasons: [['Question', 'Understand a feature or the methodology.'], ['Problem', 'Report unexpected behavior in the application.'], ['Suggestion', 'Propose an improvement or a new use case.']],
      formTitle: 'Send a message', name: 'Name', email: 'Email', subject: 'Subject', message: 'Message',
      subjects: [['question', 'Question'], ['problem', 'Problem'], ['feature', 'Feature suggestion'], ['other', 'Other']],
      placeholder: 'Describe your request and include any useful context…', send: 'Send message', sending: 'Sending…',
      privacy: 'This information is used only to process and reply to your request. Do not share sensitive financial information through this form.',
      success: 'Thank you — your message has been sent. I will reply as soon as possible.',
      error: 'Your message could not be sent. Please try again in a moment.',
    };
---

<EditorialLayout
  {lang}
  title={copy.title}
  description={copy.description}
  canonicalPath={copy.canonical}
  alternateFrPath={copy.alternateFr}
  alternateEnPath={copy.alternateEn}
  eyebrow={copy.eyebrow}
  heading={copy.heading}
  intro={copy.intro}
>
  <div class="contact-layout">
    <section class="contact-context">
      <h2>{copy.directTitle}</h2><p>{copy.directBody}</p>
      <div class="contact-reasons">
        {copy.reasons.map(([title, body], index) => <article><span>0{index + 1}</span><div><h3>{title}</h3><p>{body}</p></div></article>)}
      </div>
    </section>
    <section class="contact-panel">
      <h2>{copy.formTitle}</h2>
      <form
        class="marketing-contact-form"
        data-success={copy.success}
        data-error={copy.error}
        data-sending={copy.sending}
      >
        <div class="contact-field"><label for="contact-name">{copy.name}</label><input id="contact-name" name="name" autocomplete="name" maxlength="80" required /></div>
        <div class="contact-field"><label for="contact-email">{copy.email}</label><input id="contact-email" name="email" type="email" autocomplete="email" required /></div>
        <div class="contact-field"><label for="contact-subject">{copy.subject}</label><select id="contact-subject" name="subject">{copy.subjects.map(([value, label]) => <option value={value}>{label}</option>)}</select></div>
        <div class="contact-field"><label for="contact-message">{copy.message}</label><textarea id="contact-message" name="message" rows="7" minlength="10" maxlength="2000" placeholder={copy.placeholder} required></textarea></div>
        <p class="contact-privacy">{copy.privacy}</p>
        <button class="button" type="submit">{copy.send}<span aria-hidden="true">→</span></button>
        <p class="contact-status" role="status" aria-live="polite"></p>
      </form>
    </section>
  </div>
</EditorialLayout>

<script>
  const form = document.querySelector<HTMLFormElement>('.marketing-contact-form');
  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    const button = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    const status = form.querySelector<HTMLElement>('.contact-status');
    if (!button || !status) return;

    const originalLabel = button.innerHTML;
    button.disabled = true;
    button.textContent = form.dataset.sending ?? 'Sending…';
    status.textContent = '';
    status.className = 'contact-status';

    try {
      const values = Object.fromEntries(new FormData(form).entries());
      const response = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify(values),
      });
      if (!response.ok) throw new Error(`Contact request failed: ${response.status}`);
      form.reset();
      status.textContent = form.dataset.success ?? 'Message sent.';
      status.classList.add('is-success');
    } catch {
      status.textContent = form.dataset.error ?? 'Could not send message.';
      status.classList.add('is-error');
    } finally {
      button.disabled = false;
      button.innerHTML = originalLabel;
    }
  });
</script>
