---
import EditorialLayout from '../layouts/EditorialLayout.astro';

const { lang } = Astro.props as { lang: 'fr' | 'en' };
const isFr = lang === 'fr';
const copy = isFr
  ? {
      title: 'À propos de Runaway | Planifier sa liberté financière',
      description: 'Découvrez pourquoi Runaway a été créé, les convictions qui guident le produit et la mission de son développeur indépendant.',
      canonical: '/a-propos', alternateFr: '/a-propos', alternateEn: '/en/about',
      eyebrow: 'À PROPOS DE RUNAWAY',
      heading: 'Salut, moi c’est Léo.',
      intro: 'Je développe Runaway seul. C’est né d’une question que je me posais pour moi-même : à partir de quand mon patrimoine peut-il vraiment financer la vie que je veux ?',
      originTitle: 'Pourquoi Runaway existe',
      origin: [
        'Pendant des années, j’ai suivi mon épargne et mes investissements dans des Google Sheets qui grossissaient à chaque nouvelle idée.',
        'J’ai testé les calculateurs FIRE en ligne et quelques logiciels payants, mais je retombais sur le même compromis : soit c’était cher, soit ça s’arrêtait avant les vraies questions. Le support multi-devise, notamment, était presque toujours absent ou bancal, comme d’autres modules dont j’avais besoin. Runaway est né de ce manque.',
      ],
      creatorTitle: 'Qui construit Runaway',
      creator: [
        'Je suis software engineer avec huit ans d’expérience dans le développement d’applications web.',
        'Depuis longtemps, l’investissement et l’indépendance financière me passionnent : comment les décisions d’aujourd’hui façonnent la liberté de demain. J’ai construit Runaway pour réunir dans un seul outil ce que je cherchais ailleurs : une prise en main simple, des hypothèses qu’on modifie, des projections détaillées et une vue claire de ce qui se passe derrière les chiffres.',
      ],
      missionTitle: 'Pensé pour la France, le Canada et les États-Unis',
      mission: [
        'Je voulais un outil capable de représenter un patrimoine moderne et diversifié — actions, ETF, cryptomonnaies, liquidités et autres actifs — sans éparpiller son plan entre plusieurs applications.',
        'Franco-canadien, il me fallait un outil qui colle aux réalités de la France et du Canada : leurs devises, leurs types de comptes, leurs particularités fiscales. Les États-Unis suivent, parce que leur marché et leurs pratiques d’investissement pèsent dans presque toute planification.',
        'Je construis Runaway sur mon temps libre, avec l’ambition d’en faire l’outil que j’aurais aimé trouver : complet sans être une usine à gaz, sérieux sans être intimidant.',
      ],
      principlesTitle: 'Les principes qui guident le produit',
      principles: [
        ['Transparence', 'Les hypothèses, les méthodes et les limites doivent rester compréhensibles.'],
        ['Liberté', 'Chaque utilisateur peut modifier son scénario et explorer ses propres décisions.'],
        ['Confidentialité', 'Les informations financières méritent une conception prudente et respectueuse.'],
        ['Accessibilité', 'Planifier son avenir ne devrait pas nécessiter un tableur complexe ou un outil hors de prix.'],
      ],
      note: 'Runaway ne fournit pas de conseil financier, fiscal ou juridique personnalisé. Les résultats sont des projections hypothétiques fondées sur les informations et les hypothèses choisies par l’utilisateur.',
      method: 'Découvrir la méthodologie', sandbox: 'Essayer sans email',
    }
  : {
      title: 'About Runaway | Plan your financial freedom',
      description: 'Discover why Runaway was built, the beliefs behind the product, and the mission of its independent developer.',
      canonical: '/en/about', alternateFr: '/a-propos', alternateEn: '/en/about',
      eyebrow: 'ABOUT RUNAWAY',
      heading: 'Hi, I’m Léo.',
      intro: 'I build Runaway on my own. It started with a question I was asking for myself: when can my wealth truly fund the life I want?',
      originTitle: 'Why Runaway exists',
      origin: [
        'For years, I tracked my savings and investments in Google Sheets that grew with every new idea.',
        'I tried the online FIRE calculators and a few paid tools, but I kept hitting the same compromise: either it was expensive, or it stopped before the real questions. Multi-currency support in particular was almost always missing or clumsy, along with other modules I needed. Runaway grew out of that gap.',
      ],
      creatorTitle: 'Who builds Runaway',
      creator: [
        'I’m a software engineer with eight years of experience developing web applications.',
        'I’ve long cared about investing and financial independence: how today’s decisions shape tomorrow’s freedom. I built Runaway to bring together in one tool what I was looking for elsewhere: a simple experience, editable assumptions, detailed projections, and a clear view of what happens behind the numbers.',
      ],
      missionTitle: 'Built for France, Canada, and the US',
      mission: [
        'I wanted a tool that can represent modern, diversified wealth — stocks, ETFs, cryptocurrencies, cash, and other assets — without splitting your plan across several applications.',
        'As a French-Canadian, I needed a tool that fits the realities of both France and Canada: their currencies, account types, and tax considerations. The United States follows, because its markets and investing practices weigh on almost any plan.',
        'I build Runaway in my spare time, aiming to make the tool I wish I’d found: comprehensive without being overwhelming, serious without being intimidating.',
      ],
      principlesTitle: 'The principles behind the product',
      principles: [
        ['Transparency', 'Assumptions, methods, and limitations should remain understandable.'],
        ['Freedom', 'People can change their scenario and explore their own decisions.'],
        ['Privacy', 'Financial information deserves careful and respectful product design.'],
        ['Accessibility', 'Planning your future should not require a complex spreadsheet or an overpriced tool.'],
      ],
      note: 'Runaway does not provide personalized financial, tax, or legal advice. Results are hypothetical projections based on the information and assumptions selected by each user.',
      method: 'Explore the methodology', sandbox: 'Try without email',
    };
---

<EditorialLayout
  {lang}
  title={copy.title}
  description={copy.description}
  canonicalPath={copy.canonical}
  alternateFrPath={copy.alternateFr}
  alternateEnPath={copy.alternateEn}
  eyebrow={copy.eyebrow}
  heading={copy.heading}
  intro={copy.intro}
>
  <article class="editorial-article">
    <section class="editorial-section editorial-section--lead">
      <h2>{copy.originTitle}</h2>
      {copy.origin.map((paragraph) => <p>{paragraph}</p>)}
    </section>
    <section class="editorial-section">
      <h2>{copy.creatorTitle}</h2>
      {copy.creator.map((paragraph) => <p>{paragraph}</p>)}
    </section>
    <section class="editorial-section editorial-section--dark">
      <h2>{copy.missionTitle}</h2>
      {copy.mission.map((paragraph) => <p>{paragraph}</p>)}
    </section>
    <section class="editorial-section">
      <h2>{copy.principlesTitle}</h2>
      <div class="editorial-card-grid">
        {copy.principles.map(([title, body], index) => (
          <article class="editorial-card"><span>0{index + 1}</span><h3>{title}</h3><p>{body}</p></article>
        ))}
      </div>
    </section>
    <aside class="editorial-note"><p>{copy.note}</p></aside>
    <div class="editorial-actions">
      <a class="button" href={isFr ? '/methodologie' : '/en/methodology'}>{copy.method}<span>→</span></a>
      <a class="button button--ghost" href={`/${lang}/app/sandbox`}>{copy.sandbox}<span>↗</span></a>
    </div>
  </article>
</EditorialLayout>
