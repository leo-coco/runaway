---
interface Props {
  lang: 'fr' | 'en';
  alternatePath: string;
}

const { lang, alternatePath } = Astro.props;
const isFr = lang === 'fr';
const home = isFr ? '/' : '/en';
const appBase = `/${lang}/app`;
const examplesPath = isFr ? '/exemples' : '/en/examples';
---

<header class="site-header">
  <a class="brand" href={home} aria-label={isFr ? 'Runaway — accueil' : 'Runaway — home'}>
    <img src="/favicon.png" alt="" width="36" height="36" />
    <span>Runaway</span>
  </a>
  <nav aria-label={isFr ? 'Navigation principale' : 'Primary navigation'}>
    <a href={home}>{isFr ? 'Le Produit' : 'The Product'}</a>
    <a href={examplesPath}>{isFr ? 'Exemples' : 'Examples'}</a>
    <a href={isFr ? '/methodologie' : '/en/methodology'}>{isFr ? 'Méthodologie' : 'Methodology'}</a>
    <a href={isFr ? '/a-propos' : '/en/about'}>{isFr ? 'À propos' : 'About'}</a>
    <a href={isFr ? '/contact' : '/en/contact'}>Contact</a>
  </nav>
  <div class="header-actions">
    <button
      class="theme-toggle"
      type="button"
      aria-label={isFr ? 'Activer le thème sombre' : 'Switch to dark theme'}
      title={isFr ? 'Changer de thème' : 'Change theme'}
      data-light-label={isFr ? 'Activer le thème clair' : 'Switch to light theme'}
      data-dark-label={isFr ? 'Activer le thème sombre' : 'Switch to dark theme'}
    >
      <svg class="theme-toggle__sun" viewBox="0 0 24 24" aria-hidden="true">
        <circle cx="12" cy="12" r="4"></circle>
        <path d="M12 2v2M12 20v2M4.93 4.93l1.42 1.42M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.42-1.42M17.66 6.34l1.41-1.41"></path>
      </svg>
      <svg class="theme-toggle__moon" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M20.5 14.2A8.5 8.5 0 0 1 9.8 3.5 8.5 8.5 0 1 0 20.5 14.2Z"></path>
      </svg>
    </button>
    <a class="lang-link" href={alternatePath} hreflang={isFr ? 'en' : 'fr'}>{isFr ? 'EN' : 'FR'}</a>
    <a class="text-link" href={`${appBase}/signin`}>{isFr ? 'Se connecter' : 'Sign in'}</a>
    <a class="button button--small" href={examplesPath}>{isFr ? 'Essayer' : 'Try it'}</a>
  </div>
</header>

<script>
  const syncThemeToggle = (button: HTMLButtonElement) => {
    const isDark = document.documentElement.dataset.theme === 'dark';
    button.setAttribute(
      'aria-label',
      isDark ? button.dataset.lightLabel! : button.dataset.darkLabel!,
    );
    button.setAttribute('aria-pressed', String(isDark));
  };

  document.querySelectorAll<HTMLButtonElement>('.theme-toggle').forEach((button) => {
    syncThemeToggle(button);
    button.addEventListener('click', () => {
      const nextTheme = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
      document.documentElement.dataset.theme = nextTheme;
      document.documentElement.style.colorScheme = nextTheme;
      localStorage.setItem('runaway/marketing-theme', nextTheme);
      document
        .querySelector<HTMLMetaElement>('meta[name="theme-color"]')
        ?.setAttribute('content', nextTheme === 'dark' ? '#0d0d0d' : '#f5f2ec');
      document.querySelectorAll<HTMLButtonElement>('.theme-toggle').forEach(syncThemeToggle);
    });
  });
</script>
