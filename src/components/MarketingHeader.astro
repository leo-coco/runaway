---
interface Props {
  lang: 'fr' | 'en';
  alternatePath: string;
}

const { lang, alternatePath } = Astro.props;
const isFr = lang === 'fr';
const home = isFr ? '/' : '/en';
const appBase = `/${lang}/app`;
const examplesPath = isFr ? '/exemples' : '/en/examples';
---

<header class="site-header">
  <a class="brand" href={home} aria-label={isFr ? 'Runaway — accueil' : 'Runaway — home'}>
    <img src="/favicon.png" alt="" width="36" height="36" />
    <span>Runaway</span>
  </a>
  <nav aria-label={isFr ? 'Navigation principale' : 'Primary navigation'}>
    <a href={home}>{isFr ? 'Le Produit' : 'The Product'}</a>
    <a href={examplesPath}>{isFr ? 'Exemples' : 'Examples'}</a>
    <a href={isFr ? '/methodologie' : '/en/methodology'}>{isFr ? 'Méthodologie' : 'Methodology'}</a>
    <a href={isFr ? '/a-propos' : '/en/about'}>{isFr ? 'À propos' : 'About'}</a>
    <a href={isFr ? '/contact' : '/en/contact'}>Contact</a>
  </nav>
  <div class="header-actions">
    <a class="lang-link" href={alternatePath} hreflang={isFr ? 'en' : 'fr'}>{isFr ? 'EN' : 'FR'}</a>
    <a class="text-link" href={`${appBase}/signin`}>{isFr ? 'Se connecter' : 'Sign in'}</a>
    <a class="button button--small" href={examplesPath}>{isFr ? 'Essayer' : 'Try it'}</a>
  </div>
</header>
