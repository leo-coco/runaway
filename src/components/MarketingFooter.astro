---
interface Props {
  lang: 'fr' | 'en';
  line?: string;
}

const { lang, line = 'Know when you’re free.' } = Astro.props;
const isFr = lang === 'fr';
const home = isFr ? '/' : '/en';
const links = isFr
  ? [
      { href: '/a-propos', label: 'À propos' },
      { href: '/methodologie', label: 'Méthodologie' },
      { href: '/contact', label: 'Contact' },
      { href: '/confidentialite', label: 'Confidentialité' },
      { href: '/mentions-legales', label: 'Mentions légales' },
      { href: '/conditions-utilisation', label: 'CGU' },
      { href: '/conditions-vente', label: 'CGV' },
    ]
  : [
      { href: '/en/about', label: 'About' },
      { href: '/en/methodology', label: 'Methodology' },
      { href: '/en/contact', label: 'Contact' },
      { href: '/en/privacy', label: 'Privacy' },
      { href: '/en/legal-notice', label: 'Legal notice' },
      { href: '/en/terms', label: 'Terms' },
      { href: '/en/sales-terms', label: 'Sales terms' },
    ];
---

<footer class="marketing-footer">
  <a class="brand" href={home}>
    <img src="/favicon.png" alt="" width="32" height="32" />
    <span>Runaway</span>
  </a>
  <p>{line}</p>
  <div class="marketing-footer__meta">
    <span>© {new Date().getFullYear()} Runaway</span>
    {links.map((link) => <a href={link.href}>{link.label}</a>)}
  </div>
</footer>
