---
import Analytics from '@vercel/analytics/astro';
import '../styles/marketing.css';
import geistRegular from '@fontsource/geist-sans/files/geist-sans-latin-400-normal.woff2?url';
import geistBold from '@fontsource/geist-sans/files/geist-sans-latin-700-normal.woff2?url';

interface Props {
  lang: 'fr' | 'en';
  title: string;
  description: string;
  canonicalPath: string;
  alternateFrPath?: string;
  alternateEnPath?: string;
  faq?: { question: string; answer: string }[];
  kind?: 'landing' | 'page';
  dateModified?: string;
}

const {
  lang,
  title,
  description,
  canonicalPath,
  alternateFrPath = '/',
  alternateEnPath = '/en',
  faq = [],
  kind = 'page',
  dateModified,
} = Astro.props;
const canonical = new URL(canonicalPath, Astro.site);
const ogImage = new URL('/og-image.png', Astro.site);
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Runaway',
  url: new URL('/', Astro.site).href,
  logo: new URL('/favicon.png', Astro.site).href,
};
const schema = kind === 'landing'
  ? [organizationSchema, {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Runaway',
    applicationCategory: 'FinanceApplication',
    operatingSystem: 'Web',
    url: canonical.href,
    description,
    offers: {
      '@type': 'AggregateOffer',
      priceCurrency: 'USD',
      lowPrice: '0',
      highPrice: '69',
      offerCount: '2',
    },
  }, ...(faq.length > 0 ? [{
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faq.map((item) => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: { '@type': 'Answer', text: item.answer },
    })),
  }] : [])]
  : [organizationSchema, {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: title,
    url: canonical.href,
    description,
    inLanguage: lang,
    ...(dateModified ? { dateModified } : {}),
  }];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="fr" href={new URL(alternateFrPath, Astro.site)} />
    <link rel="alternate" hreflang="en" href={new URL(alternateEnPath, Astro.site)} />
    <link rel="alternate" hreflang="x-default" href={new URL(alternateFrPath, Astro.site)} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preload" href={geistRegular} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={geistBold} as="font" type="font/woff2" crossorigin />
    <meta name="theme-color" content="#0d0d0d" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Runaway" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={lang === 'fr' ? 'fr_FR' : 'en_US'} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    <Analytics />
  </head>
  <body>
    <slot />
  </body>
</html>
