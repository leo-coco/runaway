---
import '../styles/marketing.css';

interface Props {
  lang: 'fr' | 'en';
  title: string;
  description: string;
  canonicalPath: string;
  faq: { question: string; answer: string }[];
}

const { lang, title, description, canonicalPath, faq } = Astro.props;
const canonical = new URL(canonicalPath, Astro.site);
const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Runaway',
    applicationCategory: 'FinanceApplication',
    operatingSystem: 'Web',
    url: canonical.href,
    description,
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faq.map((item) => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: { '@type': 'Answer', text: item.answer },
    })),
  },
];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="fr" href={new URL('/', Astro.site)} />
    <link rel="alternate" hreflang="en" href={new URL('/en', Astro.site)} />
    <link rel="alternate" hreflang="x-default" href={new URL('/', Astro.site)} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="theme-color" content="#0d0d0d" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Runaway" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body>
    <slot />
  </body>
</html>
