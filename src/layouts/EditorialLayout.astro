---
import MarketingFooter from '../components/MarketingFooter.astro';
import MarketingHeader from '../components/MarketingHeader.astro';
import MarketingLayout from './MarketingLayout.astro';

interface Props {
  lang: 'fr' | 'en';
  title: string;
  description: string;
  canonicalPath: string;
  alternateFrPath: string;
  alternateEnPath: string;
  eyebrow: string;
  heading: string;
  intro: string;
  dateModified?: string;
}

const {
  lang,
  title,
  description,
  canonicalPath,
  alternateFrPath,
  alternateEnPath,
  eyebrow,
  heading,
  intro,
  dateModified,
} = Astro.props;
const isFr = lang === 'fr';
const alternate = isFr ? alternateEnPath : alternateFrPath;
---

<MarketingLayout
  {lang}
  {title}
  {description}
  {canonicalPath}
  {alternateFrPath}
  {alternateEnPath}
  {dateModified}
>
  <MarketingHeader
    {lang}
    alternatePath={alternate}
    signupLabel={isFr ? 'Créer mon plan' : 'Build my plan'}
  />

  <main class="editorial-main">
    <header class="editorial-hero section-shell">
      <p class="eyebrow"><span></span>{eyebrow}</p>
      <h1>{heading}</h1>
      <p>{intro}</p>
    </header>
    <div class="editorial-body section-shell">
      <slot />
    </div>
  </main>

  <MarketingFooter {lang} />
</MarketingLayout>
