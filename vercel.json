{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    { "source": "/fr", "destination": "/", "permanent": true },
    { "source": "/:lang(en|fr)/signin", "destination": "/:lang/app/signin", "permanent": true },
    { "source": "/:lang(en|fr)/sign-in", "destination": "/:lang/app/signin", "permanent": true },
    {
      "source": "/:lang(en|fr)/reset-password",
      "destination": "/:lang/app/reset-password",
      "permanent": true
    },
    { "source": "/:lang(en|fr)/plan/:path*", "destination": "/:lang/app/plan/:path*", "permanent": true },
    { "source": "/:lang(en|fr)/account", "destination": "/:lang/app/account", "permanent": true },
    { "source": "/:lang(en|fr)/admin", "destination": "/:lang/app/admin", "permanent": true }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/[...route]" },
    { "source": "/:lang(en|fr)/app", "destination": "/app/index.html" },
    { "source": "/:lang(en|fr)/app/(.*)", "destination": "/app/index.html" },
    { "source": "/app", "destination": "/app/index.html" },
    { "source": "/app/(.*)", "destination": "/app/index.html" }
  ],
  "headers": [
    {
      "source": "/(favicon.ico|favicon.png|favicon.svg|apple-touch-icon.png|og-image.png|icons.svg)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=()" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://*.ingest.sentry.io https://*.ingest.us.sentry.io; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
        },
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/_astro/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
