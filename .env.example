# Retire on Model — API keys
# Copy this file to ".env" and fill in your keys.
# The app validates client keys at boot (src/config/env.ts) and server keys at
# API startup (server/env.ts), surfacing a clear error if any is missing.

# CoinGecko needs no key (free public API). Base URL is overridable if you use a Pro plan.
VITE_COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# ─── Server (backend) — NOT exposed to the client bundle (no VITE_ prefix) ───
# Alpha Vantage & ExchangeRate calls are proxied and cached server-side, so their
# keys live here (never shipped to the browser). See server/routes/market.ts.
# Alpha Vantage — US/CA stock & ETF quotes. Free key: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=
# ExchangeRate-API — live FX rates. Free key: https://www.exchangerate-api.com/
EXCHANGERATE_API_KEY=
# Neon pooled connection string. https://neon.com
DATABASE_URL=
# Better Auth signing secret. Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public origin the app runs on. Dev = Vite origin; prod = your deployed URL.
BETTER_AUTH_URL=http://localhost:5173
# Resend API key (re_…). https://resend.com
RESEND_API_KEY=
# Verified sender. Dev: "onboarding@resend.dev". Prod: your verified domain.
EMAIL_FROM=Retire on Model <onboarding@resend.dev>
