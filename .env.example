# Retire on Model — environment
# Copy this file to ".env" and fill in your values.

# ─── Client (bundled) — safe to expose (no secrets) ───
# CoinGecko needs no key (free public API). Base URL is overridable if you use a Pro plan.
VITE_COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# ─── Server (backend) — NOT exposed to the client bundle (no VITE_ prefix) ───
# Market-data provider keys. The client reaches these providers through the
# same-origin /api/market proxy, so the keys never enter the browser bundle.
# Stock & ETF quotes (US/CA/EU) come from Yahoo and need no key.
# ExchangeRate-API — live FX rates. Free key: https://www.exchangerate-api.com/
EXCHANGERATE_API_KEY=

# Neon pooled connection string. https://neon.com
DATABASE_URL=
# Better Auth signing secret. Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=
# AES-256 key encrypting plan data at rest. Generate: openssl rand -base64 32
# MUST differ from BETTER_AUTH_SECRET. Store in a secret manager — if lost, ALL
# stored plan data is permanently unrecoverable.
DATA_ENCRYPTION_KEY=
# Public origin the app runs on. Dev = Vite origin; prod = your deployed URL.
BETTER_AUTH_URL=http://localhost:5173
# Resend API key (re_…). https://resend.com
RESEND_API_KEY=
# Verified sender. Dev: "onboarding@resend.dev". Prod: your verified domain.
EMAIL_FROM=Retire on Model <onboarding@resend.dev>
# Mailbox the footer contact form delivers to. Replies go to the sender directly.
CONTACT_EMAIL_TO=

# ─── Stripe (billing) — OPTIONAL ───
# Leave blank to disable self-serve billing: /api/billing/* returns 503 and the
# paywall shows "checkout coming soon". Set all four to enable subscriptions.
# Secret key (sk_test_… in test mode). https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Webhook signing secret (whsec_…). From `stripe listen` in dev, or the dashboard
# webhook endpoint in prod. Verifies the /api/billing/webhook payload.
STRIPE_WEBHOOK_SECRET=
# Recurring Price id for the regular annual Premium subscription (price_…).
STRIPE_PRICE_ID=
# Recurring Price id charged while the intro offer is active (pricing.introActive).
STRIPE_INTRO_PRICE_ID=
